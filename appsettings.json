{
  "Auth": {
    "Mode": "both",
    "StaticToken": "vendelo-static-token",
    "OAuthClientId": "vendelo-client",
    "OAuthClientSecret": "vendelo-secret",
    "OAuthRefreshToken": "vendelo-oauth-refresh-token",
    "OAuthAccessToken": "vendelo-oauth-access-token",
    "OAuthExpiresIn": 3600,
    "OAuthTokenType": "Bearer"
  },
  "Behavior": {
    "EnableDebugRoutes": true,
    "ForceErrorForService": ""
  },
  "Storage": {
    "DataFile": "data/db.json"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  },
  "AllowedHosts": "*"
}

