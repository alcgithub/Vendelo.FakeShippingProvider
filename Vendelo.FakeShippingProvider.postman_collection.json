                 {
                     "name":  "Calculate Shipping",
                     "request":  {
                                     "method":  "POST",
                                     "header":  [
                                                    {
                                                        "key":  "Authorization",
                                                        "value":  "Bearer {{token}}",
                                                        "type":  "text"
                                                    },
                                                    {
                                                        "key":  "Content-Type",
                                                        "value":  "application/json",
                                                        "type":  "text"
                                                    }
                                                ],
                                     "body":  {
                                                  "mode":  "raw",
                                                  "raw":  "{\n  \"from\": { \"postal_code\": \"01001000\" },\n  \"to\": { \"postal_code\": \"13083000\" },\n  \"carrier\": { \"id\": \"VEND_CAR_001\", \"erp_id\": \"ERP_CAR_001\" },\n  \"products\": [\n    {\n      \"id\": \"SKU-1\",\n      \"width\": 12,\n      \"height\": 8,\n      \"length\": 20,\n      \"weight\": 0.8,\n      \"quantity\": 2,\n      \"unit_price\": 100,\n      \"discount_total\": 0,\n      \"insurance_value\": 10,\n      \"available_stock\": 25\n    }\n  ]\n}"
                                              },
                                     "url":  {
                                                 "raw":  "{{baseUrl}}/api/v1/shipment/calculate",
                                                 "host":  [
                                                              "{{baseUrl}}"
                                                          ],
                                                 "path":  [
                                                              "api",
                                                              "v1",
                                                              "shipment",
                                                              "calculate"
                                                          ]
                                             }
                                 },
                     "event":  [
                                   {
                                       "listen":  "test",
                                       "script":  {
                                                      "type":  "text/javascript",
                                                      "exec":  [
                                                                   "pm.test(\"Calculate 200\", function () {",
                                                                   "  pm.response.to.have.status(200);",
                                                                   "});",
                                                                   "var json = pm.response.json();",
                                                                   "pm.test(\"Retorna array de cotacoes\", function () {",
                                                                   "  pm.expect(Array.isArray(json)).to.eql(true);",
                                                                   "  pm.expect(json.length).to.be.above(0);",
                                                                   "});",
                                                                   "pm.test(\"Primeira cotacao tem id\", function () {",
                                                                   "  pm.expect(json[0].id).to.exist;",
                                                                   "});",
                                                                   "pm.environment.set(\"serviceId\", json[0].id);"
                                                               ]
                                                  }
                                   }
                               ]
