                 {
                     "name":  "OAuth Authorize (Get Code)",
                     "request":  {
                                     "method":  "GET",
                                     "header":  [

                                                ],
                                     "url":  {
                                                 "raw":  "{{baseUrl}}/oauth/authorize?response_type=code\u0026client_id={{clientId}}\u0026redirect_uri={{redirectUri}}\u0026state={{oauthState}}\u0026scope=shipping-calculate",
                                                 "host":  [
                                                              "{{baseUrl}}"
                                                          ],
