                                                          ],
                                                 "query":  [
                                                               {
                                                                   "key":  "response_type",
                                                                   "value":  "code"
                                                               },
                                                               {
                                                                   "key":  "client_id",
                                                                   "value":  "{{clientId}}"
                                                               },
                                                               {
                                                                   "key":  "redirect_uri",
                                                                   "value":  "{{redirectUri}}"
                                                               },
                                                               {
                                                                   "key":  "state",
                                                                   "value":  "{{oauthState}}"
                                                               },
                                                               {
                                                                   "key":  "scope",
                                                                   "value":  "shipping-calculate"
                                                               }
                                                           ]
                                             }
                                 },
                     "protocolProfileBehavior":  {
                                                     "followRedirects":  false
                                                 },
                     "event":  [
                                   {
                                       "listen":  "test",
                                       "script":  {
                                                      "type":  "text/javascript",
                                                      "exec":  [
                                                                   "pm.test(\"Authorize 302\", function () {",
                                                                   "  pm.response.to.have.status(302);",
                                                                   "});",
                                                                   "var location = pm.response.headers.get(\"Location\") || pm.response.headers.get(\"location\");",
                                                                   "pm.test(\"Tem Location\", function () {",
                                                                   "  pm.expect(location).to.exist;",
                                                                   "});",
                                                                   "var match = location ? location.match(/[?\u0026]code=([^\u0026]+)/) : null;",
                                                                   "pm.test(\"Tem code\", function () {",
                                                                   "  pm.expect(match).to.not.eql(null);",
                                                                   "});",
                                                                   "if (match \u0026\u0026 match[1]) {",
                                                                   "  pm.collectionVariables.set(\"authCode\", decodeURIComponent(match[1]));",
                                                                   "}"
                                                               ]
                                                  }
                                   }
                               ]
