              "  pm.response.to.have.status(200);",
              "});",
              "var json = pm.response.json();",
              "pm.test(\"OrderId confere\", function () {",
              "  pm.expect(json.order_id).to.eql(pm.environment.get(\"orderId\"));",
              "});",
              "pm.test(\"Tracking confere\", function () {",
              "  pm.expect(json.tracking).to.eql(pm.environment.get(\"trackingCode\"));",
              "});"
            ]
          }
        }
